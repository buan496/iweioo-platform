{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://iweioo.com/contracts/events/event-envelope.schema.json",
  "title": "iweioo integration event envelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "specversion",
    "id",
    "source",
    "type",
    "subject",
    "time",
    "datacontenttype",
    "data_classification",
    "data"
  ],
  "properties": {
    "specversion": {
      "const": "1.0"
    },
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "source": {
      "type": "string",
      "format": "uri-reference"
    },
    "type": {
      "type": "string",
      "pattern": "^iweioo\\.[a-z0-9_.-]+\\.v[1-9][0-9]*$"
    },
    "subject": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "time": {
      "type": "string",
      "format": "date-time"
    },
    "datacontenttype": {
      "const": "application/json"
    },
    "traceparent": {
      "type": "string",
      "pattern": "^[0-9a-f]{2}-[0-9a-f]{32}-[0-9a-f]{16}-[0-9a-f]{2}$"
    },
    "data_classification": {
      "enum": ["public", "internal", "personal"]
    },
    "data": {
      "type": "object"
    }
  }
}
